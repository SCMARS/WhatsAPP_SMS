# ========================
# Railway auto-sets DATABASE_URL when you add PostgreSQL plugin
# Format: postgresql://user:pass@host:port/db
# (config.py auto-converts to asyncpg format)
# ========================
DATABASE_URL=postgresql+asyncpg://wrwa:wrwa_secret@localhost:5432/wr_whatsapp

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
AGENT_ID=your_agent_id

# Google Gemini (для анализа фото)
GEMINI_API_KEY=your_gemini_api_key

# Green API
INSTANCE_ID=your_instance_id
INSTANCE_API_TOKEN=your_instance_api_token

# App
API_SECRET_KEY=your_secret_key_here
DEBUG=false
